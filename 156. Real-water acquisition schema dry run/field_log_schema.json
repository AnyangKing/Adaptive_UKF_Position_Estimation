{
  "schema": "real-water-block-log-1",
  "description": "Block-level field acquisition and analysis contract for fixed versus carrier-agile USBL validation.",
  "fields": {
    "session_id": {"type": "string", "required": true},
    "record_status": {"type": "enum", "values": ["mock", "measured"], "required": true},
    "block_id": {"type": "string", "required": true},
    "timestamp_utc": {"type": "datetime_with_timezone", "required": true},
    "tier": {"type": "enum", "values": ["T1", "T2", "T3"], "required": true},
    "location_id": {"type": "string", "required": true},
    "sequence_design": {"type": "enum", "values": ["ABBA", "randomized"], "required": true},
    "sequence_position": {"type": "integer", "minimum": 1, "required": true},
    "mode": {"type": "enum", "values": ["fixed", "hop"], "required": true},
    "schedule_id": {"type": "string", "required": true},
    "pings": {"type": "integer", "minimum": 40, "required": true},
    "target_state": {"type": "enum", "values": ["static", "drift"], "required": true},
    "drift_direction": {"type": "enum", "values": ["none", "radial", "tangential", "mixed"], "required": true},
    "target_speed_mps": {"type": "number", "minimum": 0, "maximum": 1, "required": true},
    "range_m": {"type": "number", "minimum_exclusive": 0, "required": true},
    "water_depth_m": {"type": "number", "minimum_exclusive": 0, "required": true},
    "receiver_depth_m": {"type": "number", "minimum": 0, "required": true},
    "transmitter_depth_m": {"type": "number", "minimum": 0, "required": true},
    "sound_speed_mps": {"type": "number", "minimum": 1300, "maximum": 1700, "required": true},
    "water_temperature_c": {"type": "number", "minimum": -5, "maximum": 40, "required": true},
    "surface_state": {"type": "enum", "values": ["calm", "small_waves", "rough"], "required": true},
    "noise_state": {"type": "enum", "values": ["quiet", "vessel", "wind", "biological", "mixed", "unknown"], "required": true},
    "ground_truth_method": {"type": "enum", "values": ["rtk_gps_depth", "mooring_geometry", "surveyed_tank", "other"], "required": true},
    "ground_truth_sigma_m": {"type": "number", "minimum": 0, "required": true},
    "array_id": {"type": "string", "required": true},
    "calibration_id": {"type": "string", "required": true},
    "transmitter_id": {"type": "string", "required": true},
    "sample_rate_hz": {"type": "integer", "minimum": 96000, "required": true},
    "clock_sync_method": {"type": "string", "required": true},
    "carrier_min_khz": {"type": "number", "minimum": 20, "maximum": 50, "required": true},
    "carrier_max_khz": {"type": "number", "minimum": 20, "maximum": 50, "required": true},
    "carrier_count": {"type": "integer", "minimum": 1, "required": true},
    "lfm_bandwidth_khz": {"type": "number", "minimum_exclusive": 0, "required": true},
    "lfm_duration_ms": {"type": "number", "minimum_exclusive": 0, "required": true},
    "toa_valid_fraction": {"type": "number", "minimum": 0, "maximum": 1, "required": true},
    "tdoa_valid_fraction": {"type": "number", "minimum": 0, "maximum": 1, "required": true},
    "doa_valid_fraction": {"type": "number", "minimum": 0, "maximum": 1, "required": true},
    "rmse_mean_m": {"type": "number", "minimum": 0, "required": true},
    "rmse_median_m": {"type": "number", "minimum": 0, "required": true},
    "rmse_p90_m": {"type": "number", "minimum": 0, "required": true},
    "doa_el_residual_lag1": {"type": "number", "minimum": -1, "maximum": 1, "required": true},
    "matched_filter_snr_db": {"type": "number", "minimum": -50, "maximum": 100, "required": true},
    "late_energy_ratio": {"type": "number", "minimum": 0, "required": true},
    "gross_error_count": {"type": "integer", "minimum": 0, "required": true},
    "exclusion_flag": {"type": "boolean", "required": true},
    "exclusion_reason": {"type": "string", "required": false},
    "raw_data_uri": {"type": "string", "required": true},
    "notes": {"type": "string", "required": false}
  }
}
